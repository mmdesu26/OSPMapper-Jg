# ====== SERVER CONFIGURATION ======
SERVER_IP=192.168.1.100
NODE_ENV=production

# ====== DATABASE ======
DB_HOST=postgres
DB_PORT=5432
POSTGRES_DB=osp_mapper
POSTGRES_USER=osp_user
POSTGRES_PASSWORD=GANTI_PASSWORD_KUAT_MIN_12_CHAR

# ====== AUTHENTICATION ======
JWT_ACCESS_SECRET=GANTI_ACCESS_SECRET_PANJANG_MIN_32_CHAR
JWT_REFRESH_SECRET=GANTI_REFRESH_SECRET_PANJANG_MIN_32_CHAR
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ====== REDIS (CACHING) ======
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_REDIS_PASSWORD

# ====== MINIO (OBJECT STORAGE) ======
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=GANTI_MINIO_PASSWORD_MIN_8_CHAR
MINIO_BUCKET=osp-assets

# ====== API CONFIGURATION ======
PORT=3001
DB_SYNC=true
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://SERVER_IP/api/v1

# ====== CORS ======
CORS_ORIGIN=http://localhost:3000,http://SERVER_IP
